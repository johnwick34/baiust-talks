// firestore.rules
// Deploy with: firebase deploy --only firestore:rules
// Or paste into Firebase Console → Firestore → Rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ── Talks (posts) ──────────────────────────────────────────────────────
    match /talks/{talkId} {
      // Anyone signed in can read all talks (radius filtering done client-side)
      allow read: if isSignedIn();

      // Only signed-in users can create; uid must match auth
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.content is string
        && request.resource.data.content.size() > 0
        && request.resource.data.content.size() <= 280
        && request.resource.data.lat is number
        && request.resource.data.lon is number;

      // Only upvote/downvote increments allowed on update (no content edits)
      allow update: if isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['upvotes', 'downvotes']);

      // Only the author can delete their own talk
      allow delete: if isOwner(resource.data.uid);
    }

    // ── Users (alias profiles) ─────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isSignedIn();
      allow write: if isOwner(uid);
    }

    // ── Chats ─────────────────────────────────────────────────────────────
    match /chats/{chatId} {
      // Only participants can read/update the chat document
      allow read, update: if isSignedIn()
        && request.auth.uid in resource.data.participants;

      // Either participant can create
      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants.size() == 2;

      // ── Messages sub-collection ──────────────────────────────────────────
      match /messages/{msgId} {
        // Only participants of the parent chat can read/write messages
        allow read: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;

        allow create: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
          && request.resource.data.senderUid == request.auth.uid
          && request.resource.data.content is string
          && request.resource.data.content.size() > 0
          && request.resource.data.content.size() <= 500;
      }
    }

    // ── Reports (for admin moderation) ────────────────────────────────────
    match /reports/{reportId} {
      allow read: if false;   // Admin reads via Firebase console or Admin SDK
      allow create: if isSignedIn()
        && request.resource.data.reporterUid == request.auth.uid;
    }
  }
}
